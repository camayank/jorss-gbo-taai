# ============================================================================
# Jorss-GBO Tax Platform — Environment Configuration
# ============================================================================
# Copy to .env and fill in values: cp .env.example .env

# --- Required ---
JWT_SECRET=change-me-to-a-random-32-char-string
ENCRYPTION_MASTER_KEY=change-me-to-a-random-32-char-string

# --- AI Providers (at least one required for AI features) ---
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=AIza...
# PERPLEXITY_API_KEY=pplx-...

# --- Database ---
# DATABASE_URL=postgresql://user:pass@host:5432/jorss_gbo
# DATABASE_PATH=./data/jorss_gbo.db  (SQLite fallback)

# --- Redis (for sessions, rate limiting, caching) ---
# REDIS_URL=redis://:password@localhost:6379/0
# REDIS_PASSWORD=

# --- Application ---
APP_ENVIRONMENT=development
ENABLE_TEST_ROUTES=true
# HOST=0.0.0.0
# PORT=8000

# --- Security ---
# TRUSTED_PROXY_IPS=127.0.0.1,::1
# MFA_BACKUP_SECRET=change-me-random-32-chars

# --- Feature Flags ---
ENABLE_TEST_ROUTES=false
# ENABLE_DEMO_MODE=false

# --- Monitoring ---
# SENTRY_DSN=https://...@sentry.io/...

# SQLite fallback path (development only)
DATABASE_PATH="./data/tax_returns.db"

# Connection pool (OPTIONAL)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10


# =============================================================================
# REDIS (REQUIRED for production)
# =============================================================================

# Redis URL (REQUIRED for sessions, caching, Celery broker)
# Upstash example: rediss://default:password@host:6379
REDIS_URL=redis://localhost:6379/0

# Session storage backend: "redis" (recommended) or "sqlite" (default)
SESSION_STORAGE_TYPE=redis
SESSION_EXPIRY_HOURS=24
SESSION_TIMEOUT_MINUTES=30


# =============================================================================
# SECURITY — ALL REQUIRED IN PRODUCTION
# =============================================================================
# Generate each: python3 -c "import secrets; print(secrets.token_hex(32))"

# Application secret key (min 32 chars)
APP_SECRET_KEY=

# JWT signing key (min 32 chars)
JWT_SECRET=
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_SECONDS=28800    # 8 hours
REFRESH_TOKEN_EXPIRE_DAYS=30

# Auth service secret (min 32 chars)
AUTH_SECRET_KEY=

# CSRF protection secret (min 32 chars)
CSRF_SECRET_KEY=

# Password hashing salt (min 16 chars)
PASSWORD_SALT=

# PII encryption key (min 32 chars)
# WARNING: Losing this key = losing access to encrypted data!
ENCRYPTION_MASTER_KEY=

# SSN hashing secret (min 32 chars)
SSN_HASH_SECRET=

# Serializer secret for signed tokens (min 32 chars)
SERIALIZER_SECRET_KEY=

# HMAC key for audit log integrity (min 32 chars)
AUDIT_HMAC_KEY=

# HTTPS enforcement (MUST be true in production)
# APP_ENFORCE_HTTPS=true


# =============================================================================
# AI PROVIDERS (REQUIRED — at least one key needed)
# =============================================================================
# The platform auto-selects the best available provider.

# OpenAI (GPT models — primary AI features)
OPENAI_API_KEY=

# Anthropic (Claude — complex tax reasoning) — OPTIONAL
# ANTHROPIC_API_KEY=

# Google (Gemini — multimodal analysis) — OPTIONAL
# GOOGLE_API_KEY=

# Perplexity (real-time tax research) — OPTIONAL
# PERPLEXITY_API_KEY=

# AI feature flags (OPTIONAL — all default to true)
AI_CHAT_ENABLED=true
AI_REPORT_NARRATIVES_ENABLED=true
AI_SAFETY_CHECKS_ENABLED=true


# =============================================================================
# OCR (OPTIONAL — defaults to Tesseract)
# =============================================================================

# Provider: tesseract (local/free), aws (Textract — needs boto3 + AWS creds)
OCR_PROVIDER="tesseract"
OCR_CONFIDENCE_THRESHOLD=70

# AWS Textract (only if OCR_PROVIDER=aws)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION="us-east-1"


# =============================================================================
# EMAIL (OPTIONAL — null provider if unconfigured)
# =============================================================================

# Provider: sendgrid (recommended), smtp, ses
# EMAIL_PROVIDER="sendgrid"
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL="noreply@yourdomain.com"

# SMTP alternative
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL="noreply@example.com"


# =============================================================================
# STRIPE PAYMENTS (OPTIONAL — for CPA payment collection)
# =============================================================================

# Stripe Connect (platform collects payments on behalf of CPAs)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_CLIENT_ID="ca_..."


# =============================================================================
# MONITORING (RECOMMENDED for production)
# =============================================================================

LOG_LEVEL="INFO"
ENABLE_MONITORING=true

# Sentry error tracking
# SENTRY_DSN="https://..."

# Google Analytics
# GOOGLE_ANALYTICS_ID="G-..."


# =============================================================================
# FEATURE FLAGS (OPTIONAL — sensible defaults)
# =============================================================================

UNIFIED_FILING=true
DB_PERSISTENCE=true
NEW_LANDING=true
OLD_WORKFLOWS=false
SCENARIOS_ENABLED=true


# =============================================================================
# BRANDING (OPTIONAL — white-label customization)
# =============================================================================

PLATFORM_NAME="Tax Filing Platform"
COMPANY_NAME="Your CPA Firm"
PLATFORM_TAGLINE="Professional Tax Filing Made Simple"
BRAND_PRIMARY_COLOR="#667eea"
BRAND_SECONDARY_COLOR="#764ba2"
BRAND_LOGO_URL="/static/logo.svg"
BRAND_FAVICON_URL="/static/favicon.ico"
SUPPORT_EMAIL="support@example.com"
SUPPORT_PHONE="1-800-TAX-HELP"
COMPANY_WEBSITE="https://example.com"
TERMS_URL="/legal/terms"
PRIVACY_URL="/legal/privacy"


# =============================================================================
# DATA RETENTION / COMPLIANCE (OPTIONAL)
# =============================================================================

SESSION_RETENTION_HOURS=72
ORPHAN_UPLOAD_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=2555        # ~7 years (regulatory minimum)
TAX_DATA_RETENTION_DAYS=2555

# =============================================================================
# FILE STORAGE (for CPA branding uploads: profile photos, signatures, logos)
# Leave blank to use local filesystem fallback (./uploads/)
# =============================================================================
# AWS S3
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Cloudflare R2 (alternative to S3)
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# CDN base URL (optional, prepended to all storage keys)
STORAGE_CDN_BASE=
# Local upload root (used when S3/R2 not configured)
LOCAL_UPLOAD_DIR=./uploads

# =============================================================================
# BACKUP STORAGE (optional — S3 offsite backup for pg_dump files)
# =============================================================================
# BACKUP_S3_BUCKET=your-backup-bucket
# BACKUP_DELETE_LOCAL_AFTER_UPLOAD=false


# =============================================================================
# FUNNEL ORCHESTRATION (OPTIONAL)
# =============================================================================

LEAD_REVENUE_SHARE_PERCENT=15.0
HIGH_VALUE_REVENUE_SHARE_PERCENT=12.0
AUTO_ASSIGNMENT_ENABLED=true
ASSIGNMENT_ALGORITHM=round_robin     # round_robin | complexity_match | capacity
MAX_LEADS_PER_CPA_PER_DAY=10
SEND_REPORT_TO_LEAD=true
SEND_REPORT_TO_CPA=true
SEND_HOT_LEAD_ALERTS=true
AUTO_ENROLL_NURTURE=true
