# =============================================================================
# Jorss-GBO CPA Lead Platform — Production Environment (VPS)
# =============================================================================
# Copy to .env.production and fill in all values marked CHANGE_ME.
#
# Generate all 9 security secrets at once:
#   python3 -c "import secrets; [print(f'{k}={secrets.token_hex(32)}') for k in ['APP_SECRET_KEY','JWT_SECRET','AUTH_SECRET_KEY','CSRF_SECRET_KEY','PASSWORD_SALT','ENCRYPTION_MASTER_KEY','SSN_HASH_SECRET','SERIALIZER_SECRET_KEY','AUDIT_HMAC_KEY']]"
# =============================================================================


# =============================================================================
# DOMAIN & APPLICATION
# =============================================================================

DOMAIN=CHANGE_ME                         # e.g. app.yourdomain.com
APP_URL=https://CHANGE_ME                # e.g. https://app.yourdomain.com
APP_ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4
APP_ENFORCE_HTTPS=true
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES="pdf,png,jpg,jpeg,gif,tif,tiff"
CORS_ORIGINS=https://CHANGE_ME           # Same as APP_URL


# =============================================================================
# DATABASE — Docker PostgreSQL
# =============================================================================

DATABASE_URL=postgresql://jorss:CHANGE_ME_DB_PASSWORD@postgres:5432/jorss_gbo
POSTGRES_DB=jorss_gbo
POSTGRES_USER=jorss
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD  # Must match DATABASE_URL password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10


# =============================================================================
# REDIS — Docker Redis (password-protected)
# =============================================================================

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
SESSION_STORAGE_TYPE=redis
SESSION_EXPIRY_HOURS=24
SESSION_TIMEOUT_MINUTES=30


# =============================================================================
# CELERY — Uses Redis DBs 1 and 2
# =============================================================================

CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/2
CELERY_CONCURRENCY=2


# =============================================================================
# SECURITY SECRETS — ALL REQUIRED
# =============================================================================
# Generate with the one-liner above, then paste values here.

APP_SECRET_KEY=CHANGE_ME
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=28800
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_SECRET_KEY=CHANGE_ME
CSRF_SECRET_KEY=CHANGE_ME
PASSWORD_SALT=CHANGE_ME
ENCRYPTION_MASTER_KEY=CHANGE_ME
SSN_HASH_SECRET=CHANGE_ME
SERIALIZER_SECRET_KEY=CHANGE_ME
AUDIT_HMAC_KEY=CHANGE_ME


# =============================================================================
# AI PROVIDERS — At least one required
# =============================================================================

OPENAI_API_KEY=CHANGE_ME
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# PERPLEXITY_API_KEY=

AI_CHAT_ENABLED=true
AI_REPORT_NARRATIVES_ENABLED=true
AI_SAFETY_CHECKS_ENABLED=true


# =============================================================================
# EMAIL (SendGrid recommended)
# =============================================================================

# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=CHANGE_ME
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com


# =============================================================================
# STRIPE PAYMENTS
# =============================================================================

# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CLIENT_ID=ca_...


# =============================================================================
# MONITORING
# =============================================================================

LOG_LEVEL=INFO
ENABLE_MONITORING=true
# SENTRY_DSN=https://...


# =============================================================================
# OCR
# =============================================================================

OCR_PROVIDER=tesseract
OCR_CONFIDENCE_THRESHOLD=70


# =============================================================================
# FEATURE FLAGS
# =============================================================================

UNIFIED_FILING=true
DB_PERSISTENCE=true
NEW_LANDING=true
OLD_WORKFLOWS=false
SCENARIOS_ENABLED=true


# =============================================================================
# BRANDING
# =============================================================================

PLATFORM_NAME="Tax Filing Platform"
COMPANY_NAME="Your CPA Firm"
SUPPORT_EMAIL=support@yourdomain.com
